>>SOURCE FORMAT FREE
IDENTIFICATION DIVISION.
PROGRAM-ID. BENCH-COBOL.

DATA DIVISION.
WORKING-STORAGE SECTION.
78 N VALUE 1000.
78 BS VALUE 32.
78 SIZE-MAT VALUE 1000000.

01 A-MAT.
   05 A-ELEM OCCURS 1000000 TIMES COMP-2.
01 BT-MAT.
   05 BT-ELEM OCCURS 1000000 TIMES COMP-2.
01 C-MAT.
   05 C-ELEM OCCURS 1000000 TIMES COMP-2.

01 I       PIC S9(9) COMP-5.
01 J       PIC S9(9) COMP-5.
01 K       PIC S9(9) COMP-5.
01 II      PIC S9(9) COMP-5.
01 JJ      PIC S9(9) COMP-5.
01 IIMAX   PIC S9(9) COMP-5.
01 JJMAX   PIC S9(9) COMP-5.
01 POS     PIC S9(9) COMP-5.
01 POSA    PIC S9(9) COMP-5.
01 POSB    PIC S9(9) COMP-5.
01 IDX     PIC S9(9) COMP-5.
01 TMP     PIC S9(9) COMP-5.
01 Q       PIC S9(9) COMP-5.
01 R       PIC S9(9) COMP-5.
01 SUMV    COMP-2.
01 CHK     COMP-2.
01 TSTART  PIC 9(8).
01 TEND    PIC 9(8).
01 TDIFF   PIC S9(9) COMP-5.
01 MS      PIC S9(9) COMP-5.

PROCEDURE DIVISION.
MAIN.
    PERFORM VARYING I FROM 0 BY 1 UNTIL I >= N
        PERFORM VARYING J FROM 0 BY 1 UNTIL J >= N
            COMPUTE POS = I * N + J + 1
            COMPUTE TMP = I * 131 + J * 17 + 13
            DIVIDE TMP BY 1000 GIVING Q REMAINDER R
            COMPUTE A-ELEM(POS) = R * 0.001 - 0.5

            COMPUTE POS = J * N + I + 1
            COMPUTE TMP = I * 19 + J * 137 + 7
            DIVIDE TMP BY 1000 GIVING Q REMAINDER R
            COMPUTE BT-ELEM(POS) = R * 0.001 - 0.5
        END-PERFORM
    END-PERFORM

    ACCEPT TSTART FROM TIME

    PERFORM VARYING II FROM 0 BY BS UNTIL II >= N
        COMPUTE IIMAX = II + BS - 1
        IF IIMAX >= N
            COMPUTE IIMAX = N - 1
        END-IF

        PERFORM VARYING JJ FROM 0 BY BS UNTIL JJ >= N
            COMPUTE JJMAX = JJ + BS - 1
            IF JJMAX >= N
                COMPUTE JJMAX = N - 1
            END-IF

            PERFORM VARYING I FROM II BY 1 UNTIL I > IIMAX
                PERFORM VARYING J FROM JJ BY 1 UNTIL J > JJMAX
                    MOVE 0 TO SUMV
                    PERFORM VARYING K FROM 0 BY 1 UNTIL K >= N
                        COMPUTE POSA = I * N + K + 1
                        COMPUTE POSB = J * N + K + 1
                        COMPUTE SUMV = SUMV + A-ELEM(POSA) * BT-ELEM(POSB)
                    END-PERFORM
                    COMPUTE POS = I * N + J + 1
                    MOVE SUMV TO C-ELEM(POS)
                END-PERFORM
            END-PERFORM
        END-PERFORM
    END-PERFORM

    ACCEPT TEND FROM TIME

    COMPUTE TDIFF = TEND - TSTART
    IF TDIFF < 0
        COMPUTE TDIFF = TDIFF + 24000000
    END-IF
    COMPUTE MS = TDIFF * 10

    MOVE 0 TO CHK
    PERFORM VARYING IDX FROM 0 BY 97 UNTIL IDX >= SIZE-MAT
        COMPUTE POS = IDX + 1
        COMPUTE CHK = CHK + C-ELEM(POS)
    END-PERFORM

    DISPLAY "language COBOL pure"
    DISPLAY "time_ms " MS
    DISPLAY "checksum " CHK
    STOP RUN.
