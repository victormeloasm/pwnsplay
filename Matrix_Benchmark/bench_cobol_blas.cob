>>SOURCE FORMAT FREE
IDENTIFICATION DIVISION.
PROGRAM-ID. BENCH-COBOL-BLAS.

DATA DIVISION.
WORKING-STORAGE SECTION.
78 NCONST VALUE 1000.
78 SIZE-MAT VALUE 1000000.
78 CBLAS-COL-MAJOR VALUE 102.
78 CBLAS-NO-TRANS VALUE 111.

01 A-MAT.
   05 A-ELEM OCCURS 1000000 TIMES COMP-2.
01 B-MAT.
   05 B-ELEM OCCURS 1000000 TIMES COMP-2.
01 C-MAT.
   05 C-ELEM OCCURS 1000000 TIMES COMP-2.

01 ORDER-VAR  PIC S9(9) COMP-5 VALUE 102.
01 TRANS-A    PIC S9(9) COMP-5 VALUE 111.
01 TRANS-B    PIC S9(9) COMP-5 VALUE 111.
01 MVAR       PIC S9(9) COMP-5 VALUE 1000.
01 NVAR       PIC S9(9) COMP-5 VALUE 1000.
01 KVAR       PIC S9(9) COMP-5 VALUE 1000.
01 LDA        PIC S9(9) COMP-5 VALUE 1000.
01 LDB        PIC S9(9) COMP-5 VALUE 1000.
01 LDC        PIC S9(9) COMP-5 VALUE 1000.
01 ALPHA      COMP-2 VALUE 1.0.
01 BETA       COMP-2 VALUE 0.0.

01 CLOCK-MONOTONIC PIC S9(9) COMP-5 VALUE 1.
01 TS-START.
   05 TS-START-SEC  PIC S9(18) COMP-5.
   05 TS-START-NSEC PIC S9(18) COMP-5.
01 TS-END.
   05 TS-END-SEC  PIC S9(18) COMP-5.
   05 TS-END-NSEC PIC S9(18) COMP-5.

01 I       PIC S9(9) COMP-5.
01 J       PIC S9(9) COMP-5.
01 POS     PIC S9(9) COMP-5.
01 IDX     PIC S9(9) COMP-5.
01 ROWIDX  PIC S9(9) COMP-5.
01 COLIDX  PIC S9(9) COMP-5.
01 TMP     PIC S9(9) COMP-5.
01 Q       PIC S9(9) COMP-5.
01 R       PIC S9(9) COMP-5.
01 RC      PIC S9(9) COMP-5.
01 MS      COMP-2.
01 CHK     COMP-2.

PROCEDURE DIVISION.
MAIN.
    PERFORM VARYING I FROM 0 BY 1 UNTIL I >= NCONST
        PERFORM VARYING J FROM 0 BY 1 UNTIL J >= NCONST
            COMPUTE POS = I + J * NCONST + 1

            COMPUTE TMP = I * 131 + J * 17 + 13
            DIVIDE TMP BY 1000 GIVING Q REMAINDER R
            COMPUTE A-ELEM(POS) = R * 0.001 - 0.5

            COMPUTE TMP = I * 19 + J * 137 + 7
            DIVIDE TMP BY 1000 GIVING Q REMAINDER R
            COMPUTE B-ELEM(POS) = R * 0.001 - 0.5
        END-PERFORM
    END-PERFORM

    CALL STATIC "cblas_dgemm" USING
        BY VALUE ORDER-VAR
        BY VALUE TRANS-A
        BY VALUE TRANS-B
        BY VALUE MVAR
        BY VALUE NVAR
        BY VALUE KVAR
        BY VALUE ALPHA
        BY REFERENCE A-MAT
        BY VALUE LDA
        BY REFERENCE B-MAT
        BY VALUE LDB
        BY VALUE BETA
        BY REFERENCE C-MAT
        BY VALUE LDC

    CALL STATIC "clock_gettime" USING BY VALUE CLOCK-MONOTONIC BY REFERENCE TS-START RETURNING RC

    CALL STATIC "cblas_dgemm" USING
        BY VALUE ORDER-VAR
        BY VALUE TRANS-A
        BY VALUE TRANS-B
        BY VALUE MVAR
        BY VALUE NVAR
        BY VALUE KVAR
        BY VALUE ALPHA
        BY REFERENCE A-MAT
        BY VALUE LDA
        BY REFERENCE B-MAT
        BY VALUE LDB
        BY VALUE BETA
        BY REFERENCE C-MAT
        BY VALUE LDC

    CALL STATIC "clock_gettime" USING BY VALUE CLOCK-MONOTONIC BY REFERENCE TS-END RETURNING RC

    COMPUTE MS =
        (TS-END-SEC - TS-START-SEC) * 1000.0
        + (TS-END-NSEC - TS-START-NSEC) / 1000000.0

    MOVE 0 TO CHK
    PERFORM VARYING IDX FROM 0 BY 97 UNTIL IDX >= SIZE-MAT
        DIVIDE IDX BY NCONST GIVING ROWIDX REMAINDER COLIDX
        COMPUTE POS = ROWIDX + COLIDX * NCONST + 1
        COMPUTE CHK = CHK + C-ELEM(POS)
    END-PERFORM

    DISPLAY "language COBOL OpenBLAS FFI"
    DISPLAY "time_ms " MS
    DISPLAY "checksum " CHK
    STOP RUN.
